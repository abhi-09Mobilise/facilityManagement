{
  "name": "azure-blob-svc",
  "version": "1.0.0",
  "private": true,
  "description": "Sidecar HTTP service that uploads / fetches / deletes blobs in Azure Blob Storage. Sits behind the main FM API.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.17.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  }
}
