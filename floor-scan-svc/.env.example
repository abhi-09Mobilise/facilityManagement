# Floor-scan microservice (FastAPI + OpenCV)
# Copy this to .env and tweak. Read by app.py via os.environ.

# ---------- Network ----------
# Bind address. Keep 127.0.0.1 in production so only the Node backend on
# the same machine can reach it. Use 0.0.0.0 only if Node runs on a
# different host inside a private network.
HOST=127.0.0.1
PORT=5001

# Comma-separated browser origins allowed by CORS. The browser NEVER hits
# this service directly in our setup (the Node API proxies /scan), so '*'
# is fine. If you ever expose it directly, set:
#   ALLOWED_ORIGINS=https://fms.onmobilise.com
ALLOWED_ORIGINS=*

# Max image upload (bytes). Default 10 MB.
MAX_UPLOAD_BYTES=10485760

# ---------- Detection tuning ----------
# Pixel area bounds — units = pixels at the image's native resolution.
CHAIR_MIN_PX_AREA=60
CHAIR_MAX_PX_AREA=500
TABLE_MIN_PX_AREA=2500
TABLE_MAX_PX_AREA=90000

# 0..1. Shapes above CIRCULARITY_THRESHOLD are classified as round tables.
CIRCULARITY_THRESHOLD=0.75

# 0..1. Contour-area / bounding-box-area must exceed this for rect tables.
RECT_FILL_THRESHOLD=0.85

# IoU threshold for the dedupe NMS pass.
DEDUPE_IOU=0.5
