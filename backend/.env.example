# ---------- Server ----------
PORT=4002
NODE_ENV=production

# Comma-separated list of allowed browser origins. Use '*' only in dev.
# For prod, include EVERY scheme+host the browser will load the SPA from.
CORS_ORIGIN=https://fms.onmobilise.com

# ---------- MySQL ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fms_app
DB_PASSWORD=replace-with-strong-password
DB_NAME=socampus_fm
DB_CONNECTION_LIMIT=10

# ---------- Auth ----------
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-48-chars
JWT_EXPIRES_IN=12h

# ---------- Uploads ----------
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# ---------- Mail (SMTP) ----------
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true
MAIL_FROM="Facility Booking <no-reply@onmobilise.com>"

# Used inside email bodies for password-reset / approve-via-mail links.
# Must match the public origin the browser uses.
APP_PUBLIC_URL=https://fms.onmobilise.com

# Token validity for invite / password-reset (minutes)
PASSWORD_RESET_TTL_MIN=1440

# ---------- Floor-scan microservice ----------
# Where the Python OpenCV service is reachable from this Node process.
# Keep it on localhost — never expose Python directly to the internet.
FLOOR_SCAN_SVC_URL=http://127.0.0.1:5001

# ---------- Cron endpoints ----------
# Shared secret for /api/cron/* endpoints. Without it those routes return 503.
# Use a long random string and pass it as ?key=... from your external cron.
CRON_SECRET=replace-with-long-random-string

# How often the in-process checkout sweeper runs (ms). Default 5 min.
CHECKOUT_SWEEP_MS=300000

# ---------- Azure Blob upload sidecar ----------
# Where the upload sidecar lives. Keep on localhost — never expose it directly.
AZURE_BLOB_SVC_URL=http://127.0.0.1:5002
# Must match INTERNAL_KEY in azure-blob-svc/.env.
AZURE_BLOB_INTERNAL_KEY=replace-with-long-random-string
