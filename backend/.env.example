# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MySQL - point at the existing Socampus DB or a fresh one
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=socampus_fm
DB_CONNECTION_LIMIT=10

# Auth
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Mail (SMTP) - works with Gmail, SendGrid, AWS SES, Mailtrap, etc.
# In dev, Mailtrap (https://mailtrap.io) gives you a safe inbox.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM="Facility Booking <no-reply@example.com>"
# Used to build links inside emails (e.g. password reset)
APP_PUBLIC_URL=http://localhost:5173
# Token validity for invite / password-reset (minutes)
PASSWORD_RESET_TTL_MIN=1440
